{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ServiceHealth": {
    "IntervalSeconds": 10,
    "Services": [
      { "Name": "gps-svc", "Host": "localhost", "Port": 5200, "HealthPath": "/api/status", "CheckType": "Http" },
      { "Name": "compass-svc", "Host": "localhost", "Port": 5100, "CheckType": "Tcp" },
      { "Name": "sdr-svc", "Host": "localhost", "Port": 5101, "CheckType": "Tcp" },
      { "Name": "hw-test", "Host": "localhost", "Port": 5000, "HealthPath": "/health", "CheckType": "Http" }
    ]
  }
}
