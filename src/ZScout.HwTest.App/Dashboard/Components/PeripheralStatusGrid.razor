@inject RunCommandService RunSvc
@inject LiveEventPublisher LiveEvents
@implements IDisposable

@if (_evidence.Count == 0 && !_loaded)
{
    <div class="text-muted small">Loading peripheral status…</div>
}
else
{
    <div class="row g-3">
        @foreach (var pid in _peripherals)
        {
            var ev = _evidence.FirstOrDefault(e => e.PeripheralId == pid);
            var status = _liveStatus.TryGetValue(pid, out var s) ? s
                         : ev?.HealthSnapshot.Values.TryGetValue("status", out var sv) == true
                           ? Enum.TryParse<PeripheralStatus>(sv?.ToString(), out var ps) ? ps : PeripheralStatus.Unknown
                           : PeripheralStatus.Unknown;
            var isProbing = status == PeripheralStatus.Unknown && ev is null && _cmdLog.ContainsKey(pid);

            <div class="col-sm-6 col-lg-3">
                <div class="card peripheral-card status-@status.ToString().ToLower()">
                    <div class="card-body py-2 px-3">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <strong class="small">@pid</strong>
                            <span class="d-flex align-items-center gap-1">
                                @if (isProbing)
                                {
                                    <span class="spinner-border spinner-border-sm text-primary" role="status"></span>
                                    <span class="badge bg-info">Probing…</span>
                                }
                                <span class="badge badge-@status.ToString().ToLower()">@status</span>
                            </span>
                        </div>
                        @if (ev is not null)
                        {
                            <div class="text-muted" style="font-size:0.75rem">
                                <div>Dependency: @(ev.DependencyAvailable ? "✓ available" : "✗ unavailable")</div>
                                <div>Samples: @ev.SampleCount</div>
                                @if (ev.DiagnosticMessages.Count > 0)
                                {
                                    <div class="mt-1 text-truncate" title="@ev.DiagnosticMessages[^1]">
                                        @ev.DiagnosticMessages[^1]
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="text-muted" style="font-size:0.75rem">Awaiting probe…</div>
                        }
                        @if (_cmdLog.TryGetValue(pid, out var entries) && entries.Count > 0)
                        {
                            <div class="cmd-log">
                                @foreach (var entry in entries)
                                {
                                    <div class="cmd-log-entry @(entry.IsError ? "error" : "")">
                                        <div class="cmd-label">$ @entry.Cmd</div>
                                        <div class="cmd-output">@entry.Output</div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter, EditorRequired] public string RunId { get; set; } = "";

    private static readonly PeripheralId[] _peripherals = Enum.GetValues<PeripheralId>();
    private List<PeripheralEvidence> _evidence = [];
    private Dictionary<PeripheralId, PeripheralStatus> _liveStatus = [];
    private Dictionary<PeripheralId, List<(string Cmd, string Output, bool IsError, DateTimeOffset Ts)>> _cmdLog = [];
    private bool _loaded;

    protected override async Task OnParametersSetAsync()
    {
        _evidence = (await RunSvc.GetEvidenceAsync(RunId)).ToList();
        _loaded = true;
    }

    protected override void OnInitialized()
    {
        LiveEvents.PeripheralStatusChanged += OnPeripheralStatusChanged;
        LiveEvents.CommandProgressReceived += OnCommandProgress;
    }

    private void OnPeripheralStatusChanged(object? sender, PeripheralStatusEventArgs e)
    {
        if (e.RunId != RunId) return;
        _ = InvokeAsync(async () =>
        {
            _liveStatus[e.PeripheralId] = e.Status;
            // Refresh evidence once the probe has finished
            _evidence = (await RunSvc.GetEvidenceAsync(RunId)).ToList();
            StateHasChanged();
        });
    }

    private void OnCommandProgress(object? sender, CommandProgressEventArgs e)
    {
        if (e.RunId != RunId) return;
        _ = InvokeAsync(() =>
        {
            if (!_cmdLog.ContainsKey(e.PeripheralId))
                _cmdLog[e.PeripheralId] = [];
            _cmdLog[e.PeripheralId].Add((e.Command, e.Output, e.IsError, e.TimestampUtc));
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        LiveEvents.PeripheralStatusChanged -= OnPeripheralStatusChanged;
        LiveEvents.CommandProgressReceived -= OnCommandProgress;
    }
}
