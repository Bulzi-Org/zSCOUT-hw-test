@page "/manual-tests"
@rendermode InteractiveServer
@using Microsoft.JSInterop
@using ZScout.HwTest.App.Hardware.Sdr
@inject IJSRuntime JS
@inject SdrCaptureValidator CaptureValidator

<PageTitle>Manual Tests – zSCOUT</PageTitle>

<h4 class="mb-3">Manual Test Reference</h4>
<p class="text-muted small mb-4">Step-by-step commands to verify each peripheral from the host OS or container shell. Click the copy button to copy a command to your clipboard.</p>

<div class="accordion" id="manualTestAccordion">

    <!-- GPS -->
    <div class="accordion-item">
        <h2 class="accordion-header" id="headingGps">
            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseGps" aria-expanded="true" aria-controls="collapseGps">
                📡 GPS (MicoAir MG-A01 via gpsd)
            </button>
        </h2>
        <div id="collapseGps" class="accordion-collapse collapse show" aria-labelledby="headingGps" data-bs-parent="#manualTestAccordion">
            <div class="accordion-body">
                <p class="small text-muted">GPS runs inside the <code>zscout-gps-svc</code> container (Tier 2). Confirm the FT232 USB-to-TTL adapter is plugged in and GPS module TX→adapter RX.</p>

                <h6>Host OS Shell</h6>
                @foreach (var cmd in GpsHostCommands)
                {
                    <div class="d-flex align-items-start gap-2 mb-2">
                        <code class="flex-grow-1" style="white-space:pre-wrap">@cmd</code>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => CopyToClipboardAsync(cmd)">Copy</button>
                    </div>
                }

                <h6 class="mt-3">Container Shell (via docker exec)</h6>
                @foreach (var cmd in GpsContainerCommands)
                {
                    <div class="d-flex align-items-start gap-2 mb-2">
                        <code class="flex-grow-1" style="white-space:pre-wrap">@cmd</code>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => CopyToClipboardAsync(cmd)">Copy</button>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- SDR -->
    <div class="accordion-item">
        <h2 class="accordion-header" id="headingSdr">
            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseSdr" aria-expanded="false" aria-controls="collapseSdr">
                📻 SDR (Wavelet-Lab uSDR via SoapySDR)
            </button>
        </h2>
        <div id="collapseSdr" class="accordion-collapse collapse" aria-labelledby="headingSdr" data-bs-parent="#manualTestAccordion">
            <div class="accordion-body">
                <p class="small text-muted">Confirm the uSDR is seated in the M.2 slot with the A+E→M-key adapter fitted.</p>

                <h6>Host OS Shell</h6>
                @foreach (var cmd in SdrHostCommands)
                {
                    <div class="d-flex align-items-start gap-2 mb-2">
                        <code class="flex-grow-1" style="white-space:pre-wrap">@cmd</code>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => CopyToClipboardAsync(cmd)">Copy</button>
                    </div>
                }

                <h6 class="mt-3">Container Shell</h6>
                @foreach (var cmd in SdrContainerCommands)
                {
                    <div class="d-flex align-items-start gap-2 mb-2">
                        <code class="flex-grow-1" style="white-space:pre-wrap">@cmd</code>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => CopyToClipboardAsync(cmd)">Copy</button>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- HaLow -->
    <div class="accordion-item">
        <h2 class="accordion-header" id="headingHalow">
            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseHalow" aria-expanded="false" aria-controls="collapseHalow">
                📶 HaLow (Morse Micro MM8108)
            </button>
        </h2>
        <div id="collapseHalow" class="accordion-collapse collapse" aria-labelledby="headingHalow" data-bs-parent="#manualTestAccordion">
            <div class="accordion-body">
                <p class="small text-muted">MM8108 is integrated on the CM5-IO-BASE-B. Confirm antenna is attached.</p>

                <h6>Host OS Shell</h6>
                @foreach (var cmd in HalowHostCommands)
                {
                    <div class="d-flex align-items-start gap-2 mb-2">
                        <code class="flex-grow-1" style="white-space:pre-wrap">@cmd</code>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => CopyToClipboardAsync(cmd)">Copy</button>
                    </div>
                }

                <h6 class="mt-3">Container Shell</h6>
                @foreach (var cmd in HalowContainerCommands)
                {
                    <div class="d-flex align-items-start gap-2 mb-2">
                        <code class="flex-grow-1" style="white-space:pre-wrap">@cmd</code>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => CopyToClipboardAsync(cmd)">Copy</button>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Compass -->
    <div class="accordion-item">
        <h2 class="accordion-header" id="headingCompass">
            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseCompass" aria-expanded="false" aria-controls="collapseCompass">
                🧭 Compass (QMC5883L via I²C)
            </button>
        </h2>
        <div id="collapseCompass" class="accordion-collapse collapse" aria-labelledby="headingCompass" data-bs-parent="#manualTestAccordion">
            <div class="accordion-body">
                <p class="small text-muted">QMC5883L connected to I²C header. SDA→GPIO2, SCL→GPIO3, 4.7kΩ pull-ups. Default address 0x0D.</p>

                <h6>Host OS Shell</h6>
                @foreach (var cmd in CompassHostCommands)
                {
                    <div class="d-flex align-items-start gap-2 mb-2">
                        <code class="flex-grow-1" style="white-space:pre-wrap">@cmd</code>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => CopyToClipboardAsync(cmd)">Copy</button>
                    </div>
                }

                <h6 class="mt-3">Container Shell</h6>
                @foreach (var cmd in CompassContainerCommands)
                {
                    <div class="d-flex align-items-start gap-2 mb-2">
                        <code class="flex-grow-1" style="white-space:pre-wrap">@cmd</code>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => CopyToClipboardAsync(cmd)">Copy</button>
                    </div>
                }
            </div>
        </div>
    </div>

</div>

<!-- SDR Waveform Capture Validator panel (new for #74) -->
<div class="card mt-4">
    <div class="card-header">
        📻 SDR Auto-Discover + Raw Waveform Capture Validator
        <span class="badge bg-info ms-2">Phase B</span>
    </div>
    <div class="card-body">
        <p class="small text-muted mb-2">
            On-demand test: auto-discovers an active cell uplink (tries curated LTE/5G FR1 f/bw candidates) using the sdr-svc raw capture endpoint.
            Reports chosen freq/bandwidth, HEX sample of raw float IQ prefix, transmission count + RSSI/SNR aggregate stats (client-side 10*log10 mean power, noise floor est),
            plus GPS fix + wall time per detected burst. Proves arbitrary supported f/bw capture + analysis.
            Uses graceful 404 handling if capture endpoint not yet rolled out.
        </p>
        <button class="btn btn-primary btn-sm" @onclick="RunValidatorAsync" disabled="@isRunning">
            @if (isRunning) { <span class="spinner-border spinner-border-sm me-1"></span> } Run Auto-Discover + Capture
        </button>
        <button class="btn btn-outline-secondary btn-sm ms-2" @onclick="ClearResults" disabled="@isRunning">Clear</button>

        @if (captureResult is not null)
        {
            <div class="mt-3 border rounded p-2 small" style="background:#f8f9fa">
                <div><strong>Chosen:</strong> @(captureResult.CenterFreqHz.HasValue ? $"{captureResult.CenterFreqHz.Value / 1_000_000.0:F3} MHz" : "—") / @(captureResult.BandwidthHz.HasValue ? $"{captureResult.BandwidthHz.Value / 1_000_000.0:F1} MHz BW" : "—")</div>
                @if (!string.IsNullOrEmpty(captureResult.HexSample))
                {
                    <div class="mt-1"><strong>HEX (raw IQ prefix):</strong> <code style="word-break:break-all">@captureResult.HexSample</code></div>
                }
                <div class="mt-1">
                    <strong>Stats:</strong>
                    tx=@captureResult.TransmissionCount
                    RSSI(n=@captureResult.RssiCount range=@(captureResult.RssiMin?.ToString("F1") ?? "—")..@(captureResult.RssiMax?.ToString("F1") ?? "—"))
                    SNR(n=@captureResult.SnrCount range=@(captureResult.SnrMin?.ToString("F1") ?? "—")..@(captureResult.SnrMax?.ToString("F1") ?? "—"))
                </div>
                <div class="mt-1"><strong>Captured:</strong> @captureResult.CaptureTimeUtc.ToString("O") @(captureResult.GpsAtCapture is not null ? $" | GPS mode={captureResult.GpsAtCapture.Mode} sats={captureResult.GpsAtCapture.SatellitesUsed}" : "")</div>

                @if (captureResult.PerTransmission?.Count > 0)
                {
                    <details class="mt-1"><summary>Per-transmission details (first 5)</summary>
                        <ul class="mb-0 ps-3" style="font-size:0.8em">
                            @foreach (var tx in captureResult.PerTransmission.Take(5))
                            {
                                <li> RSSI=@tx.Rssi.ToString("F1") SNR=@tx.Snr.ToString("F1") @tx.Time.ToString("HH:mm:ss") GPS=@(tx.Gps?.HasQualifyingFix == true ? "fix" : "no")</li>
                            }
                        </ul>
                    </details>
                }

                @if (captureResult.Messages?.Count > 0)
                {
                    <div class="mt-1 text-muted" style="font-size:0.75em; max-height:6em; overflow:auto">
                        @foreach (var m in captureResult.Messages) { <div>@m</div> }
                    </div>
                }
            </div>
        }
        else if (!string.IsNullOrEmpty(validatorStatus))
        {
            <div class="mt-2 text-muted small">@validatorStatus</div>
        }
    </div>
</div>

@code {
    private async Task CopyToClipboardAsync(string text)
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
    }

    // ── SDR Capture Validator UI state & handler (added for #74) ─────────────────
    private CaptureResult? captureResult;
    private bool isRunning;
    private string? validatorStatus;

    private async Task RunValidatorAsync()
    {
        isRunning = true;
        validatorStatus = "Running auto-discover + capture...";
        captureResult = null;
        StateHasChanged();

        try
        {
            captureResult = await CaptureValidator.RunAutoDiscoverAndCaptureAsync(maxCandidates: 5, numSamples: 2048);
            validatorStatus = null;
        }
        catch (Exception ex)
        {
            validatorStatus = $"Validator error: {ex.Message}";
        }
        finally
        {
            isRunning = false;
            StateHasChanged();
        }
    }

    private void ClearResults()
    {
        captureResult = null;
        validatorStatus = null;
        StateHasChanged();
    }

    // GPS commands — Tier 2: gpsd runs inside zscout-gps-svc container, REST API on :5200
    private static readonly string[] GpsHostCommands =
    [
        "docker ps --filter name=zscout-gps-svc --format '{{.Status}}'",
        "curl -s http://localhost:5200/api/status",
        "curl -s http://localhost:5200/api/fix | python3 -m json.tool",
        "ss -tlnp | grep :5200"
    ];

    private static readonly string[] GpsContainerCommands =
    [
        "docker exec zscout-gps-svc pgrep -x gpsd && echo PASS || echo FAIL",
        "docker exec zscout-gps-svc gpspipe -r -n 5 -w",
        "docker exec zscout-gps-svc gpspipe -r -n 1 -w"
    ];

    // SDR commands
    private static readonly string[] SdrHostCommands =
    [
        "SoapySDRUtil --find",
        "SoapySDRUtil --probe",
        "SoapySDRUtil --info | grep -i lime",
        "lsusb -v 2>/dev/null | grep -A5 -i \"lime\\|wavelet\""
    ];

    private static readonly string[] SdrContainerCommands =
    [
        "SoapySDRUtil --find",
        "SoapySDRUtil --probe",
        "ls /dev/bus/usb/"
    ];

    // HaLow commands
    private static readonly string[] HalowHostCommands =
    [
        "lsmod | grep morse",
        "modinfo morse_driver",
        "sudo modprobe morse_driver",
        "ip link show",
        "find /sys/bus/sdio/devices /sys/bus/pci/devices -name '*morse*' 2>/dev/null"
    ];

    private static readonly string[] HalowContainerCommands =
    [
        "lsmod | grep morse",
        "ip link show | grep -E \"morse|wlan\"",
        "find /sys/bus/sdio/devices /sys/bus/pci/devices -name '*morse*' 2>/dev/null"
    ];

    // Compass commands
    private static readonly string[] CompassHostCommands =
    [
        "ls /dev/i2c-*",
        "i2cdetect -y 1",
        "i2cget -y 1 0x0d 0x06",
        "i2cget -y 1 0x0d 0x00"
    ];

    private static readonly string[] CompassContainerCommands =
    [
        "ls /dev/i2c-*",
        "i2cdetect -y 1",
        "i2cget -y 1 0x0d 0x06",
        "i2cget -y 1 0x0d 0x00"
    ];
}
