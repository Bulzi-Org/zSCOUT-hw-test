@page "/"
@rendermode InteractiveServer
@inject RunCommandService RunSvc
@inject LiveEventPublisher LiveEvents
@implements IDisposable

<PageTitle>Control – zSCOUT</PageTitle>

<h4 class="mb-3">Run Control</h4>

@if (_errorMsg is not null)
{
    <div class="alert alert-danger alert-dismissible mb-3" role="alert">
        @_errorMsg
        <button type="button" class="btn-close" @onclick="() => _errorMsg = null"></button>
    </div>
}

<!-- Run lifecycle / start panel -->
@if (_activeRun is null)
{
    <div class="card mb-4">
        <div class="card-body">
            <h6 class="card-title">Start New Run</h6>
                <div class="d-flex align-items-center gap-3 flex-wrap">
                <div>
                    <label class="form-label mb-1">Mode</label>
                    <select class="form-select form-select-sm" style="width:160px"
                            @bind="_selectedMode">
                        <option value="@RunMode.Host">Host</option>
                        <option value="@RunMode.Container">Container</option>
                    </select>
                    <div class="form-text text-muted mt-1">
                        @if (_selectedMode == RunMode.Host)
                        {
                            <span>Runs tests directly on the host OS. Use when the app runs outside Docker.</span>
                        }
                        else
                        {
                            <span>Runs tests inside the Docker container. Verifies hardware access through /dev bind-mounts.</span>
                        }
                    </div>
                </div>
                <div class="align-self-end">
                    <button class="btn btn-success btn-sm" @onclick="StartRunAsync"
                            disabled="@_busy">
                        @if (_busy) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Start Run
                    </button>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="card mb-4">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-2">
                <div>
                    <h6 class="card-title mb-0">Active Run</h6>
                    <small class="text-muted font-monospace">@_activeRun.RunId</small>
                </div>
                @if (_activeRun.Status is RunStatus.Queued or RunStatus.Running)
                {
                    <button class="btn btn-danger btn-sm" @onclick="StopRunAsync"
                            disabled="@_busy">Stop</button>
                }
            </div>

            <RunLifecyclePanel RunId="@_activeRun.RunId" CurrentStatus="_activeRun.Status" />
        </div>
    </div>

    <!-- Peripheral status grid -->
    <PeripheralStatusGrid RunId="@_activeRun.RunId" />

    <!-- Auto-verdict results (Completed only) -->
    @if (_activeRun.Status == RunStatus.Completed && _completedVerdicts.Count > 0)
    {
        <div class="card mt-4">
            <div class="card-body">
                <h6 class="card-title">Results Summary</h6>
                <table class="table table-sm mb-0">
                    <thead>
                        <tr>
                            <th>Peripheral</th>
                            <th>Verdict</th>
                            <th>Details</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var v in _completedVerdicts)
                        {
                            <tr>
                                <td><strong>@v.PeripheralId</strong></td>
                                <td>
                                    <span class="badge @(v.Outcome == VerdictOutcome.Pass ? "bg-success" : "bg-danger")">
                                        @v.Outcome
                                    </span>
                                </td>
                                <td class="small text-muted">@(v.FailureReason ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}

<!-- Recent runs table -->
@if (_recentRuns.Count > 0)
{
    <div class="card mt-4">
        <div class="card-body">
            <h6 class="card-title">Recent Runs</h6>
            <table class="table table-sm table-hover mb-0">
                <thead>
                    <tr>
                        <th>Run ID</th>
                        <th>Mode</th>
                        <th>Status</th>
                        <th>Outcome</th>
                        <th>Started</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in _recentRuns)
                    {
                        <tr>
                            <td class="font-monospace small">@r.RunId[..8]…</td>
                            <td>@r.Mode</td>
                            <td><span class="badge bg-secondary">@r.Status</span></td>
                            <td>
                                @if (r.OverallOutcome.HasValue)
                                {
                                    <span class="badge @(r.OverallOutcome == OverallOutcome.Pass ? "bg-success" : "bg-danger")">
                                        @r.OverallOutcome
                                    </span>
                                }
                            </td>
                            <td class="small text-muted">@r.StartedAtUtc?.ToString("yyyy-MM-dd HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private TestRun? _activeRun;
    private List<TestRun> _recentRuns = [];
    private List<PeripheralVerdict> _completedVerdicts = [];
    private RunMode _selectedMode = RunMode.Host;
    private bool _busy;
    private string? _errorMsg;

    protected override async Task OnInitializedAsync()
    {
        LiveEvents.RunStatusChanged += OnRunStatusChanged;
        await RefreshAsync();
    }

    private async Task RefreshAsync()
    {
        _activeRun = await RunSvc.GetActiveRunAsync();
        _recentRuns = (await RunSvc.GetRecentRunsAsync(8)).ToList();

        if (_activeRun?.Status == RunStatus.Completed)
            _completedVerdicts = (await RunSvc.GetVerdictsAsync(_activeRun.RunId)).ToList();
        else
            _completedVerdicts = [];
    }

    private async Task StartRunAsync()
    {
        _busy = true;
        _errorMsg = null;
        try
        {
            var (run, err) = await RunSvc.StartRunAsync(_selectedMode, "dashboard");
            if (err is not null) _errorMsg = err;
            else _activeRun = run;
            _recentRuns = (await RunSvc.GetRecentRunsAsync(8)).ToList();
        }
        finally { _busy = false; }
    }

    private async Task StopRunAsync()
    {
        if (_activeRun is null) return;
        _busy = true;
        try
        {
            var err = await RunSvc.StopRunAsync(_activeRun.RunId);
            if (err is not null) _errorMsg = err;
            await RefreshAsync();
        }
        finally { _busy = false; }
    }

    private void OnRunStatusChanged(object? sender, RunStatusEventArgs e)
    {
        _ = InvokeAsync(async () =>
        {
            await RefreshAsync();
            StateHasChanged();
        });
    }

    public void Dispose() => LiveEvents.RunStatusChanged -= OnRunStatusChanged;
}
