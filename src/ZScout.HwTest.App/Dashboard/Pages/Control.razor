@page "/"
@rendermode InteractiveServer
@inject RunCommandService RunSvc
@inject LiveEventPublisher LiveEvents
@implements IDisposable

<PageTitle>Control – zSCOUT</PageTitle>

<h4 class="mb-3">Run Control</h4>

@if (_errorMsg is not null)
{
    <div class="alert alert-danger alert-dismissible mb-3" role="alert">
        @_errorMsg
        <button type="button" class="btn-close" @onclick="() => _errorMsg = null"></button>
    </div>
}

<!-- Run lifecycle / start panel -->
@if (_activeRun is null)
{
    <div class="card mb-4">
        <div class="card-body">
            <h6 class="card-title">Start New Run</h6>
            <div class="d-flex align-items-center gap-3 flex-wrap">
                <div>
                    <label class="form-label mb-1">Mode</label>
                    <select class="form-select form-select-sm" style="width:160px"
                            @bind="_selectedMode">
                        <option value="@RunMode.Host">Host</option>
                        <option value="@RunMode.Container">Container</option>
                    </select>
                </div>
                <div class="align-self-end">
                    <button class="btn btn-success btn-sm" @onclick="StartRunAsync"
                            disabled="@_busy">
                        @if (_busy) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Start Run
                    </button>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="card mb-4">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-2">
                <div>
                    <h6 class="card-title mb-0">Active Run</h6>
                    <small class="text-muted font-monospace">@_activeRun.RunId</small>
                </div>
                @if (_activeRun.Status is RunStatus.Queued or RunStatus.Running)
                {
                    <button class="btn btn-danger btn-sm" @onclick="StopRunAsync"
                            disabled="@_busy">Stop</button>
                }
            </div>

            <RunLifecyclePanel RunId="@_activeRun.RunId" CurrentStatus="_activeRun.Status" />
        </div>
    </div>

    <!-- Peripheral status grid -->
    <PeripheralStatusGrid RunId="@_activeRun.RunId" />

    <!-- Verdict assignment (AwaitingVerdict only, Operator+) -->
    @if (_activeRun.Status == RunStatus.AwaitingVerdict)
    {
        <div class="card mt-4">
            <div class="card-body">
                <h6 class="card-title">Assign Verdicts</h6>
                <p class="text-muted small mb-3">
                    Review the evidence above and assign a pass/fail outcome for each peripheral.
                </p>
                @foreach (var row in _verdictRows)
                {
                    <div class="verdict-row">
                        <div style="width:130px">
                            <strong>@row.PeripheralId</strong>
                        </div>
                        <div class="d-flex gap-3 align-items-center flex-grow-1 flex-wrap">
                            <div class="form-check form-check-inline">
                                <input class="form-check-input" type="radio"
                                       name="verdict_@row.PeripheralId"
                                       id="pass_@row.PeripheralId"
                                       checked="@(row.Outcome == VerdictOutcome.Pass)"
                                       @onchange="() => { row.Outcome = VerdictOutcome.Pass; row.FailureReason = null; }" />
                                <label class="form-check-label" for="pass_@row.PeripheralId">Pass</label>
                            </div>
                            <div class="form-check form-check-inline">
                                <input class="form-check-input" type="radio"
                                       name="verdict_@row.PeripheralId"
                                       id="fail_@row.PeripheralId"
                                       checked="@(row.Outcome == VerdictOutcome.Fail)"
                                       @onchange="() => row.Outcome = VerdictOutcome.Fail" />
                                <label class="form-check-label" for="fail_@row.PeripheralId">Fail</label>
                            </div>
                            @if (row.Outcome == VerdictOutcome.Fail)
                            {
                                <input type="text" class="form-control form-control-sm"
                                       style="max-width:300px"
                                       placeholder="Failure reason (required)"
                                       @bind="row.FailureReason" />
                            }
                            @if (row.Submitted)
                            {
                                <span class="badge bg-success">Saved</span>
                            }
                            else
                            {
                                <button class="btn btn-primary btn-sm"
                                        @onclick="() => SubmitVerdictAsync(row)"
                                        disabled="@(row.Outcome == VerdictOutcome.Fail && string.IsNullOrWhiteSpace(row.FailureReason))">
                                    Submit
                                </button>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    }
}

<!-- Recent runs table -->
@if (_recentRuns.Count > 0)
{
    <div class="card mt-4">
        <div class="card-body">
            <h6 class="card-title">Recent Runs</h6>
            <table class="table table-sm table-hover mb-0">
                <thead>
                    <tr>
                        <th>Run ID</th>
                        <th>Mode</th>
                        <th>Status</th>
                        <th>Outcome</th>
                        <th>Started</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in _recentRuns)
                    {
                        <tr>
                            <td class="font-monospace small">@r.RunId[..8]…</td>
                            <td>@r.Mode</td>
                            <td><span class="badge bg-secondary">@r.Status</span></td>
                            <td>
                                @if (r.OverallOutcome.HasValue)
                                {
                                    <span class="badge @(r.OverallOutcome == OverallOutcome.Pass ? "bg-success" : "bg-danger")">
                                        @r.OverallOutcome
                                    </span>
                                }
                            </td>
                            <td class="small text-muted">@r.StartedAtUtc?.ToString("yyyy-MM-dd HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private TestRun? _activeRun;
    private List<TestRun> _recentRuns = [];
    private RunMode _selectedMode = RunMode.Host;
    private bool _busy;
    private string? _errorMsg;
    private List<VerdictRow> _verdictRows = [];

    protected override async Task OnInitializedAsync()
    {
        LiveEvents.RunStatusChanged += OnRunStatusChanged;
        await RefreshAsync();
    }

    private async Task RefreshAsync()
    {
        _activeRun = await RunSvc.GetActiveRunAsync();
        _recentRuns = (await RunSvc.GetRecentRunsAsync(8)).ToList();

        if (_activeRun?.Status == RunStatus.AwaitingVerdict)
            await BuildVerdictRowsAsync();
    }

    private async Task BuildVerdictRowsAsync()
    {
        var existingVerdicts = await RunSvc.GetVerdictsAsync(_activeRun!.RunId);
        var coveredIds = existingVerdicts.Select(v => v.PeripheralId).ToHashSet();

        _verdictRows = Enum.GetValues<PeripheralId>()
            .Where(pid => !coveredIds.Contains(pid))
            .Select(pid => new VerdictRow(pid))
            .ToList();
    }

    private async Task StartRunAsync()
    {
        _busy = true;
        _errorMsg = null;
        try
        {
            var (run, err) = await RunSvc.StartRunAsync(_selectedMode, "dashboard");
            if (err is not null) _errorMsg = err;
            else _activeRun = run;
            _recentRuns = (await RunSvc.GetRecentRunsAsync(8)).ToList();
        }
        finally { _busy = false; }
    }

    private async Task StopRunAsync()
    {
        if (_activeRun is null) return;
        _busy = true;
        try
        {
            var err = await RunSvc.StopRunAsync(_activeRun.RunId);
            if (err is not null) _errorMsg = err;
            await RefreshAsync();
        }
        finally { _busy = false; }
    }

    private async Task SubmitVerdictAsync(VerdictRow row)
    {
        var (success, err) = await RunSvc.AssignVerdictAsync(
            _activeRun!.RunId, row.PeripheralId, row.Outcome, row.FailureReason, "dashboard");

        if (success) row.Submitted = true;
        else _errorMsg = err;

        // Refresh run to detect if all verdicts in and run is now Completed
        _activeRun = await RunSvc.GetRunAsync(_activeRun.RunId);
        if (_activeRun?.Status == RunStatus.Completed)
            await RefreshAsync();

        StateHasChanged();
    }

    private void OnRunStatusChanged(object? sender, RunStatusEventArgs e)
    {
        _ = InvokeAsync(async () =>
        {
            _activeRun = await RunSvc.GetActiveRunAsync();
            if (_activeRun is null)
                _recentRuns = (await RunSvc.GetRecentRunsAsync(8)).ToList();
            else if (_activeRun.Status == RunStatus.AwaitingVerdict)
                await BuildVerdictRowsAsync();
            StateHasChanged();
        });
    }

    public void Dispose() => LiveEvents.RunStatusChanged -= OnRunStatusChanged;

    private sealed class VerdictRow(PeripheralId peripheralId)
    {
        public PeripheralId PeripheralId { get; } = peripheralId;
        public VerdictOutcome Outcome { get; set; } = VerdictOutcome.Pass;
        public string? FailureReason { get; set; }
        public bool Submitted { get; set; }
    }
}
