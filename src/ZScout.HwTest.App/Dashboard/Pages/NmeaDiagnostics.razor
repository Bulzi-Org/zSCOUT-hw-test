@page "/nmea-diagnostics"
@rendermode InteractiveServer
@using Microsoft.JSInterop
@inject NmeaStreamService NmeaSvc
@inject LiveEventPublisher LiveEvents
@inject IConfiguration Config
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>NMEA Diagnostics – zSCOUT</PageTitle>

<h4 class="mb-3">NMEA Diagnostics</h4>
<p class="text-muted small mb-3">
    Live raw NMEA sentences from gps-svc <code>GET /api/stream/nmea</code> (SSE).
    <strong>Read-only diagnostic view.</strong>
</p>

<!-- Status bar -->
<div class="d-flex align-items-center gap-3 mb-3 flex-wrap">
    <span class="badge @(_connected ? "bg-success" : "bg-danger") d-flex align-items-center gap-1">
        <span class="rounded-circle d-inline-block @(_connected ? "bg-light" : "")"
              style="width:8px; height:8px;"></span>
        @(_connected ? "Connected" : "Disconnected")
    </span>
    <span class="text-muted small">@_lines.Count / @_maxLines lines</span>
    <div class="ms-auto d-flex gap-2">
        <button class="btn btn-sm @(_streaming ? "btn-outline-danger" : "btn-outline-success")"
                @onclick="ToggleStream">
            @(_streaming ? "Stop" : "Start")
        </button>
        <button class="btn btn-sm btn-outline-secondary" @onclick="ClearBuffer"
                disabled="@(_lines.Count == 0)">
            Clear
        </button>
        <button class="btn btn-sm btn-outline-secondary" @onclick="CopyToClipboardAsync"
                disabled="@(_lines.Count == 0)">
            Copy
        </button>
    </div>
</div>

<!-- NMEA output -->
<div class="card">
    <div class="card-body p-0">
        <pre id="nmeaOutput" class="nmea-output mb-0" style="height:500px; overflow-y:auto; font-size:0.8rem; padding:0.75rem; margin:0; background:#1e1e1e; color:#d4d4d4; border-radius:0.375rem;">@if (_lines.Count > 0)
{@(string.Join("\n", _lines))
}
else if (!_connected)
{<span style="color:#888">Waiting for NMEA data… Ensure gps-svc is running.</span>}
</pre>
    </div>
</div>

@code {
    private readonly List<string> _lines = [];
    private int _maxLines = 200;
    private bool _connected;
    private bool _shouldAutoScroll;
    private bool _streaming;

    protected override void OnInitialized()
    {
        // Read configurable buffer cap
        if (int.TryParse(Config["NmeaDiagnostics:MaxLines"], out var max) && max > 0)
            _maxLines = max;

        // Subscribe to NMEA events
        LiveEvents.NmeaSentenceReceived += OnNmeaSentence;
        LiveEvents.NmeaConnectionStateChanged += OnConnectionStateChanged;

        // Start the SSE stream (ref-counted)
        NmeaSvc.Subscribe();
        _streaming = true;
        _connected = NmeaSvc.IsConnected;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_shouldAutoScroll)
        {
            _shouldAutoScroll = false;
            await JS.InvokeVoidAsync("scrollToBottom", "nmeaOutput");
        }
    }

    private void OnNmeaSentence(object? sender, NmeaSentenceEventArgs e)
    {
        _ = InvokeAsync(() =>
        {
            _lines.Add(e.Sentence);

            // Cap the buffer (FR-003)
            while (_lines.Count > _maxLines)
                _lines.RemoveAt(0);

            _shouldAutoScroll = true;
            StateHasChanged();
        });
    }

    private void OnConnectionStateChanged(object? sender, NmeaConnectionStateEventArgs e)
    {
        _ = InvokeAsync(() =>
        {
            _connected = e.Connected;
            StateHasChanged();
        });
    }

    private void ToggleStream()
    {
        if (_streaming)
        {
            NmeaSvc.Unsubscribe();
            _streaming = false;
        }
        else
        {
            NmeaSvc.Subscribe();
            _streaming = true;
        }
    }

    private void ClearBuffer()
    {
        _lines.Clear();
    }

    private async Task CopyToClipboardAsync()
    {
        var text = string.Join('\n', _lines);
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
    }

    public void Dispose()
    {
        LiveEvents.NmeaSentenceReceived -= OnNmeaSentence;
        LiveEvents.NmeaConnectionStateChanged -= OnConnectionStateChanged;

        // Stop the SSE stream if last subscriber (FR-006)
        if (_streaming)
            NmeaSvc.Unsubscribe();
    }
}
