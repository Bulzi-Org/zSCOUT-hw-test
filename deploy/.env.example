# zSCOUT hw-test deploy — copy to .env and customize per CM5 node:
#   cp .env.example .env
#
# Mesh identity MUST match the MeshGate exactly (SSID is case-sensitive).

MESH_SSID=zSCOUT-Mesh
MESH_CHANNEL=28
MESH_OP_CLASS=71
MESH_S1G_PRIM_CHWIDTH=1
MESH_S1G_PRIM_1MHZ_CHAN_INDEX=3
MESH_COUNTRY=US
MESH_KEY=zMesh-01

# Unique per node on the mesh subnet (.2, .3, .4, ...)
MESH_NODE_IP=10.41.0.2/16
MESH_GATEWAY_IP=10.41.0.1
BATMAN_GW_MODE=client
MESH_ROUTING_ALGO=BATMAN_V

# Bench (Ethernet uplink): keep mesh route secondary. Field mesh-only nodes: use 0.
MESH_DEFAULT_ROUTE_METRIC=1000

# Optional: force HaLow netdev when auto-detect fails (CM5 USB hub: wlan1 / morse_usb).
# MESH_HALOW_IFACE=wlan1

MESH_INTERNET_PROBE_URL=https://1.1.1.1
MESH_INTERNET_PROBE_INTERVAL_SEC=60